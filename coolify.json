{
  "name": "Nexus Business Intelligence Platform",
  "description": "Comprehensive business intelligence platform for innovators and entrepreneurs",
  "repository": "https://github.com/Marcoby-Dev-Ops/Nexus",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "vite",
  "nodeVersion": "20",
  "healthCheckPath": "/",
  "healthCheckTimeout": 30,
  "environmentVariables": {
    "NODE_ENV": "production",
    "VITE_POSTGRES_URL": "postgresql://postgres:postgres@localhost:5433/vector_db",
    "VITE_NEXT_PUBLIC_APP_URL": "https://nexus.marcoby.net",
    "VITE_APP_URL": "https://nexus.marcoby.net"
  },
  "deployment": {
    "type": "dockerfile",
    "dockerfile": "Dockerfile",
    "port": 3000,
    "healthCheck": {
      "path": "/",
      "interval": 30,
      "timeout": 3,
      "retries": 3
    }
  },
  "domains": [
    "nexus.marcoby.net"
  ],
  "ssl": {
    "enabled": true,
    "provider": "letsencrypt",
    "email": "admin@marcoby.net",
    "redirectHttpToHttps": true
  },
  "monitoring": {
    "enabled": true,
    "metrics": ["cpu", "memory", "disk", "network"]
  },
  "backup": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "retention": 7
  }
} 