# Nexus Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# Database Configuration (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vector_db
DB_HOST=localhost
DB_PORT=5433
DB_NAME=vector_db
DB_USER=postgres
DB_PASSWORD=postgres

# PostgreSQL Configuration (for edge functions and direct connections)
VITE_POSTGRES_URL=postgresql://postgres:postgres@localhost:5433/vector_db
VITE_POSTGRES_HOST=localhost
VITE_POSTGRES_PORT=5433
VITE_POSTGRES_DB=vector_db
VITE_POSTGRES_USER=postgres
VITE_POSTGRES_PASSWORD=postgres

# AI/ML Services
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Authentik OAuth Configuration (Client-side only - client secret is server-side)
VITE_AUTHENTIK_CLIENT_ID=your_authentik_client_id_here
VITE_AUTHENTIK_BASE_URL=https://identity.yourdomain.com
AUTHENTIK_CLIENT_SECRET=your_authentik_client_secret_here

# Automation & Workflows
VITE_N8N_URL=https://n8n.yourdomain.com
VITE_N8N_API_KEY=your_n8n_api_key_here
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_API_KEY=your_n8n_api_key_here

# Payment Processing
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
VITE_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Third-Party Integrations
VITE_HUBSPOT_CLIENT_ID=your_hubspot_client_id_here
VITE_HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret_here
VITE_NINJARMM_CLIENT_ID=your_ninjarmm_client_id_here
VITE_MS_TEAMS_TENANT_ID=your_teams_tenant_id_here
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
VITE_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Feature Flags

VITE_AI_CHAT_URL=https://localhost:3001/api/ai/chat

# Development Settings
NODE_ENV=development
VITE_DEV=true

# React Configuration
# Set to 'true' to enable React StrictMode in development (helps detect side effects but causes double rendering)
VITE_ENABLE_STRICT_MODE=false
